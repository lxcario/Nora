# ─────────────────────────────────────────────────────────────────────────────
# Nora (Pixel Study OS) — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Requires Node.js >= 20 (ts-fsrs dependency).
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ─────────────────────────────────────────────────────────────────────
# Public base URL of the deployment. Used for OpenRouter attribution headers.
# Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=

# ── Supabase (required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── AI Providers ─────────────────────────────────────────────────────────────
# GROQ_API_KEY is the primary LLM provider (Feynman, research synthesis, RAG).
# OPENROUTER_API_KEY is the fallback (free tier).
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── RAG Embeddings (optional) ─────────────────────────────────────────────────
# Without OPENAI_API_KEY the app uses ranked Postgres FTS (ts_rank_cd) instead
# of vector search. Both modes are fully functional; pgvector gives semantic
# similarity, FTS gives keyword matching.
#
# Model options: text-embedding-3-small (1536 dims, default)
#                text-embedding-3-large (3072 dims — update migration 012 too)
#                text-embedding-ada-002 (1536 dims, legacy)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=

# ── Academic Search APIs (recommended) ────────────────────────────────────────
# OpenAlex and Crossref are free with no key, but passing your email enrolls
# the app in their "Polite Pool" for higher rate limits and stable access.
#
# ACADEMIC_API_MAILTO — used for:
#   • OpenAlex  ?mailto=  query parameter
#   • Crossref  ?mailto=  query parameter + User-Agent header
#
# ACADEMIC_API_EMAIL — used for:
#   • Unpaywall /v2/{doi}?email=  (REQUIRED by Unpaywall terms of service)
#     Without this, Unpaywall lookups are skipped and OA PDF ingestion is
#     unavailable (graceful degradation per spec Req 8.5).
#
# If you set only one email address, NEXT_PUBLIC_SUPPORT_EMAIL is used as
# a fallback for both ACADEMIC_API_MAILTO and ACADEMIC_API_EMAIL.
ACADEMIC_API_MAILTO=
ACADEMIC_API_EMAIL=
NEXT_PUBLIC_SUPPORT_EMAIL=

# ── Web Search (recommended for Research Desk) ────────────────────────────────
# Tavily provides AI-optimised web search with content extraction.
# Free tier: 1,000 queries/month, no credit card required.
# Get a key at https://app.tavily.com
# WITHOUT this key, Research Desk uses academic sources only (no web results).
TAVILY_API_KEY=

# ── Semantic Scholar (optional) ───────────────────────────────────────────────
# Enriches Research Desk with AI-generated TLDRs and deeper academic metadata.
# Free without a key (100 requests per 5 minutes).
# With a key: higher sustained rate limits.
# Request a key at https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# ── University Auto-Discovery (optional) ──────────────────────────────────────
# Firecrawl powers automated discovery + scraping of official university pages
# (academic calendars, curricula). Free tier works.
# WITHOUT this key, discovery degrades gracefully to manual-upload — the
# university onboarding feature is still fully usable.
# Get a key at https://www.firecrawl.dev
FIRECRAWL_API_KEY=

# ── YouTube Study Room (optional) ─────────────────────────────────────────────
# Enables YouTube video search. Without this key, users can still open videos
# by direct URL/ID.
YOUTUBE_API_KEY=

# ── Optional External Services ────────────────────────────────────────────────
# These services are NOT runtime dependencies — they run outside Next.js.
# See README.md → "Optional External Services" for integration instructions.
#
# DOCLING_URL=http://localhost:5001   # Docling REST API for advanced PDF parsing
# RAGAS is a Python evaluation tool (offline, no runtime URL needed)
